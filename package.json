{
  "name": "lipetsk-parks",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @lipetsk-parks/frontend dev",
    "build": "pnpm --filter @lipetsk-parks/frontend build",
    "preview": "pnpm --filter @lipetsk-parks/frontend preview",
    "dev:backend": "pnpm --filter @lipetsk-parks/backend dev",
    "build:backend": "pnpm --filter @lipetsk-parks/backend build",
    "start:backend": "pnpm --filter @lipetsk-parks/backend start",
    "db:generate": "pnpm --filter @lipetsk-parks/backend prisma:generate",
    "db:migrate": "pnpm --filter @lipetsk-parks/backend prisma:migrate",
    "db:studio": "pnpm --filter @lipetsk-parks/backend prisma:studio",
    "db:seed": "pnpm --filter @lipetsk-parks/backend db:seed",
    "lint": "pnpm --filter @lipetsk-parks/frontend run lint 2>/dev/null || true",
    "typecheck": "pnpm --filter @lipetsk-parks/frontend run typecheck 2>/dev/null || true && pnpm --filter @lipetsk-parks/backend run typecheck 2>/dev/null || true && pnpm --filter @lipetsk-parks/shared run typecheck 2>/dev/null || true",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules",
    "install:all": "pnpm install --frozen-lockfile"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  }
}